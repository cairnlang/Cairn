IMPORT "lib/shared.crn"
IMPORT "lib/web.crn"

"book/code/runewarden/chapters/ch23_operational_testing/data/shift_day_013.txt" argv_head_or LET source_path
8133 argv_second_int_or LET port
"127.0.0.1" LET bind_host
