            }
            _ { peer low high done SearchState }
          END
        ELSE
          peer low high done SearchState
        END

        SET_STATE
      }
    END

    STATE
    MATCH
      SearchState {
        LET peer
        LET low
        LET high
        LET done

        done NOT IF
          high low midpoint
          LET guess
          guess "guess={}" FMT SAID
          peer guess Guess SEND
          RECEIVE
            TooLow { peer guess 1 ADD high done SearchState }
            TooHigh { peer low guess 1 SUB done SearchState }
            Correct {
              guess "solved={}" FMT SAID
              peer low high T SearchState
            }
            _ { peer low high done SearchState }
          END
        ELSE
          peer low high done SearchState
        END

        SET_STATE
      }
    END

    STATE
    MATCH
      SearchState {
        LET peer
        LET low
        LET high
        LET done

        done NOT IF
          high low midpoint
          LET guess
          guess "guess={}" FMT SAID
          peer guess Guess SEND
          RECEIVE
