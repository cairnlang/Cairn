# Small supervision helpers for actor lifecycle examples.

DEF watch_exit[T] : pid[T] -> monitor[T]
  MONITOR
END

DEF await_exit[T] : pid[T] -> str
  MONITOR AWAIT
END

# Expects two blocks that each produce a pid when applied:
#   { failing_worker } { replacement_worker } restart_once
DEF restart_once[T] : block[pid[T]] block[pid[T]] -> void
  SWAP
  APPLY
  watch_exit AWAIT
  "first_exit={}" FMT SAID

  APPLY
  watch_exit AWAIT
  "second_exit={}" FMT SAID
END
