# examples/concurrency/two_pings.crn
# Demonstrates implicit actor-local RECEIVE by handling two messages in sequence.

IMPORT "lib/actor.crn"

TYPE msg = Ping

SPAWN msg {
  Ping send_self
  Ping send_self
  RECEIVE
    Ping { "ping1" SAID }
  END
  RECEIVE
    Ping { "ping2" SAID }
  END
  DROP
}
DROP
