IMPORT "rules.crn"

TEST "viewer read in dev is allowed"
  Viewer Read Dev FALSE FALSE approval_decision
  decision_name
  "allow" ASSERT_EQ
END

TEST "operator deploy in prod requires approval"
  Operator Deploy Prod FALSE FALSE approval_decision
  decision_name
  "require_approval" ASSERT_EQ
END

TEST "viewer cannot rotate secrets"
  Viewer RotateSecrets Staging FALSE FALSE approval_decision
  decision_name
  "deny" ASSERT_EQ
END

TEST "admin emergency delete in prod still needs approval"
  Admin Delete Prod TRUE FALSE approval_decision
  decision_name
  "require_approval" ASSERT_EQ
END

TEST "draft can become submitted"
  Draft Submitted valid_transition
  ASSERT_TRUE
END

TEST "draft cannot execute directly"
  Draft Executed valid_transition
  ASSERT_FALSE
END
