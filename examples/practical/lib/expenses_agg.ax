# examples/practical/lib/expenses_agg.ax — aggregate expense metrics

DEF expenses_total : [int] -> int
  SUM
END

DEF expenses_max : [int] -> int
  SORT REVERSE HEAD
END

DEF expenses_avg : [int] -> int
  DUP SUM SWAP LEN DIV
END

DEF expenses_over_100 : [int] -> int
  { 100 GT } FILTER LEN
END

DEF abs_total_nonneg : [int] -> int
  { ABS } MAP SUM
  POST DUP 0 GTE
END
