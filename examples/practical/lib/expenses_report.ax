# examples/practical/lib/expenses_report.ax — report checks for expenses workflow

DEF report_has_expense_metrics : str -> bool
  DUP "total=" CONTAINS
  SWAP DUP "max=" CONTAINS
  SWAP DUP "avg=" CONTAINS
  SWAP "over_100=" CONTAINS
  AND AND AND
END

DEF assert_true : bool -> void
  PRE { DUP }
  DROP
END
