# proven_option.ax — option MATCH proofs (v0.6.0a slice)

TYPE option = None | Some int

DEF unwrap_or_abs : option int -> int
  MATCH
    None { ABS }
    Some { SWAP DROP ABS }
  END
  POST DUP 0 GTE
END

DEF is_some_bool : option -> bool
  MATCH
    None { F }
    Some { DROP T }
  END
  POST DUP NOT OR
END

PROVE unwrap_or_abs
PROVE is_some_bool
