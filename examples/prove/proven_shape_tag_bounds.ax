# proven_shape_tag_bounds.ax — constructor narrowing from tag-bound PRE comparisons (v0.6.0y)

TYPE shape = Circle int | Square int

DEF tag_is_positive : shape -> bool
  MATCH
    Circle { DROP 0 }
    Square { DROP 1 }
  END
  0 GT
END

# PRE implies shape tag > 0, which narrows to Square for this 2-constructor ADT.
DEF square_only_abs_bounds : shape -> int
  PRE { DUP tag_is_positive }
  MATCH
    Circle { ABS }
    Square { ABS }
  END
  POST DUP 0 GTE
END

PROVE square_only_abs_bounds
