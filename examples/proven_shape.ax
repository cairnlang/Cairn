# proven_shape.ax — generic user ADT MATCH proofs (v0.6.0c slice)

TYPE shape = Circle int | Square int

DEF size_nonneg : shape -> int
  MATCH
    Circle { ABS }
    Square { ABS }
  END
  POST DUP 0 GTE
END

DEF is_circle_bool : shape -> bool
  MATCH
    Circle { DROP T }
    Square { DROP F }
  END
  POST DUP NOT OR
END

PROVE size_nonneg
PROVE is_circle_bool
