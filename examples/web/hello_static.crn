IMPORT "lib/hello_static.crn"

ARGV LEN 0 GT
IF
  ARGV HEAD
ELSE
  "127.0.0.1"
END
LET bind_host

ARGV LEN 1 GT
IF
  8089 ARGV TAIL HEAD to_int_or
ELSE
  8089
END
LET port

port bind_host port bind_host "web: serving funny pages at http://{}:{}/ and http://{}:{}/about" FMT SAID
bind_host port {
  handle_static_request
} HTTP_SERVE
