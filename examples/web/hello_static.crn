IMPORT "lib/hello_static.crn"
IMPORT "lib/web_config.crn"

"127.0.0.1" web_bind_host LET bind_host
8089 web_bind_port LET port

port bind_host port bind_host "web: serving funny pages at http://{}:{}/ and http://{}:{}/about (plus /echo, /hello, /cookie, /set-cookie)" FMT SAID
bind_host port {
  handle_static_request
} HTTP_SERVE
