DEF handle_static_route : str -> str str int
  DUP "/" "examples/web/static/index.html" route_html_file
  SWAP "/about" "examples/web/static/about.html" route_html_file
  route_or
  route_finish
END

DEF handle_method_not_allowed : -> str str int
  "method not allowed\n" http_text_method_not_allowed
END

DEF handle_static_request : str str -> str str int
  LET path
  LET method

  method "GET" EQ
  IF
    path handle_static_route
  ELSE
    path DROP
    handle_method_not_allowed
  END
END
