IMPORT "lib/todo_web.crn"
IMPORT "lib/web_config.crn"

 "127.0.0.1" web_bind_host LET bind_host

8090 web_bind_port LET port
"mnesia" web_data_backend LET data_backend

port bind_host port bind_host data_backend "web: serving todo app (backend={}) at http://{}:{}/ with POST forms at http://{}:{}/" FMT SAID
bind_host port {
  handle_todo_request
} HTTP_SERVE
