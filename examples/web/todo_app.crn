IMPORT "lib/todo_web.crn"

ARGV LEN 0 GT
IF
  ARGV HEAD
ELSE
  "127.0.0.1"
END
LET bind_host

ARGV LEN 1 GT
IF
  8090 ARGV TAIL HEAD to_int_or
ELSE
  8090
END
LET port

port bind_host port bind_host "web: serving Mnesia-backed todo app at http://{}:{}/ with POST forms at http://{}:{}/" FMT SAID
bind_host port {
  handle_todo_request
} HTTP_SERVE
