<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Pebbles Dashboard</title>
    <style>
      :root { color-scheme: light; }
      body { font-family: "Iosevka", "Fira Code", monospace; margin: 0; background: #f3f0e8; color: #1f2933; }
      main { max-width: 1080px; margin: 0 auto; padding: 1.5rem; }
      h1 { margin-top: 0; }
      .tiles { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 0.75rem; margin-bottom: 1rem; }
      .tiles article, .card { background: #fff; border: 1px solid #d4c6a1; border-radius: 8px; padding: 0.75rem; box-shadow: 0 1px 2px rgba(0,0,0,0.04); }
      .sections { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.75rem; margin-top: 1rem; }
      ul { margin: 0.4rem 0 0 1rem; padding: 0; }
      li { margin: 0.2rem 0; }
      code { font-family: inherit; font-size: 0.9rem; }
      .empty { color: #64748b; }
      .notice { background: #fff6d8; border: 1px solid #eab308; border-radius: 8px; padding: 0.7rem; }
      label { display: block; margin-bottom: 0.6rem; }
      input { width: 100%; box-sizing: border-box; padding: 0.4rem; margin-top: 0.25rem; }
      button { padding: 0.45rem 0.9rem; }
    </style>
  </head>
  <body>
    <main>
      <h1>Pebbles Dashboard</h1>
      <p>Read-only view over your local Pebbles queue.</p>
      {{{summary_html}}}
      {{{filter_html}}}
      {{{notice_html}}}
      <section class="sections">
        {{{open_html}}}
        {{{doing_html}}}
        {{{blocked_html}}}
        {{{done_html}}}
      </section>
      <section style="margin-top: 0.75rem;">
        {{{blockers_html}}}
      </section>
    </main>
  </body>
</html>
