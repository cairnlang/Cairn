IMPORT "lib/store.crn"

TEST "init keeps next id at least one"
  pebbles_store_init
  pebbles_store_next_id
  DUP 1 GTE
  ASSERT_TRUE
END

TEST "add returns monotonic ids"
  pebbles_store_clear
  pebbles_store_init
  pebbles_store_next_id LET base

  "alpha" pebbles_store_add_open LET first
  "beta" pebbles_store_add_open LET second

  first base ASSERT_EQ
  second first 1 ADD ASSERT_EQ
END

TEST "encoded row title round-trips through decode helper"
  "open|ship docs" pebble_decode_title
  "ship docs" ASSERT_EQ
END

TEST "do transition moves open pebble to doing"
  1 "open" "ship docs" "" [ ] Pebble
  pebble_transition_do
  MATCH
    Ok {
      pebble_status "doing" ASSERT_EQ
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END
END

TEST "done transition rejects already done pebbles"
  1 "done" "ship docs" "" [ ] Pebble
  pebble_transition_done
  MATCH
    Ok {
      DROP
      FALSE ASSERT_TRUE
    }
    Err {
      "already done" ASSERT_EQ
    }
  END
END

TEST "block transition requires reason"
  1 "open" "ship docs" "" [ ] Pebble
  "" pebble_transition_block
  MATCH
    Ok {
      DROP
      FALSE ASSERT_TRUE
    }
    Err {
      "block reason required" ASSERT_EQ
    }
  END
END

TEST "note transition prepends newest note"
  1 "open" "ship docs" "" [ "first" ] Pebble
  "second" pebble_transition_note
  MATCH
    Ok {
      DUP pebble_notes LEN 2 ASSERT_EQ
      pebble_notes HEAD "second" ASSERT_EQ
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END
END

TEST "store note appends through command boundary"
  pebbles_store_clear
  pebbles_store_init
  "alpha" pebbles_store_add_open LET id
  id "remember migration plan" pebbles_store_add_note
  MATCH
    Ok {
      pebble_notes HEAD "remember migration plan" ASSERT_EQ
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END
END

TEST "reopen transition moves done pebble to open"
  1 "done" "ship docs" "" [ ] Pebble
  pebble_transition_reopen
  MATCH
    Ok {
      pebble_status "open" ASSERT_EQ
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END
END

TEST "edit transition requires non-empty title"
  1 "open" "ship docs" "" [ ] Pebble
  "" pebble_transition_edit_title
  MATCH
    Ok {
      DROP
      FALSE ASSERT_TRUE
    }
    Err {
      "title required" ASSERT_EQ
    }
  END
END

TEST "text search matches notes and title case-insensitively"
  1 "blocked" "Ship Docs" "waiting" [ "Follow Up Tomorrow" ] Pebble
  "follow up" pebble_contains_text ASSERT_TRUE
  1 "open" "Budget" "" [ ] Pebble
  "ship docs" pebble_contains_text ASSERT_FALSE
END

TEST "store reopen and edit persist updated fields"
  pebbles_store_clear
  pebbles_store_init
  "draft docs" pebbles_store_add_open LET id
  id pebbles_store_mark_done
  MATCH
    Ok {
      DROP
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END

  id pebbles_store_mark_reopen
  MATCH
    Ok {
      pebble_status "open" ASSERT_EQ
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END

  id "final docs" pebbles_store_edit_title
  MATCH
    Ok {
      pebble_title "final docs" ASSERT_EQ
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END
END

TEST "snapshot line parser preserves key and value"
  "pebble/000000000001\topen|ship docs||" pebble_snapshot_line_to_row
  MATCH
    Ok {
      DUP FST "pebble/000000000001" ASSERT_EQ
      SND "open|ship docs||" ASSERT_EQ
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END
END

TEST "import lines rejects invalid header without clearing store"
  pebbles_store_clear
  pebbles_store_init
  "keep me" pebbles_store_add_open DROP
  [ "oops" ] pebbles_store_import_lines
  MATCH
    Ok {
      DROP
      FALSE ASSERT_TRUE
    }
    Err {
      "invalid snapshot header (expected pebbles-v1)" ASSERT_EQ
    }
  END
  pebbles_store_pairs LEN 1 ASSERT_EQ
END

TEST "snapshot export and import round-trips rows and next id"
  pebbles_store_clear
  pebbles_store_init
  "first" pebbles_store_add_open LET first_id
  "second" pebbles_store_add_open LET second_id

  first_id pebbles_store_mark_do
  MATCH
    Ok {
      DROP
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END

  second_id "waiting on deploy" pebbles_store_mark_block
  MATCH
    Ok {
      DROP
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END

  second_id "follow up tomorrow" pebbles_store_add_note
  MATCH
    Ok {
      DROP
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END

  pebbles_store_export_lines LET snapshot_lines

  pebbles_store_clear
  pebbles_store_pairs LEN 0 ASSERT_EQ

  snapshot_lines pebbles_store_import_lines
  MATCH
    Ok {
      3 ASSERT_EQ
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END

  pebbles_store_pairs LEN 2 ASSERT_EQ
  pebbles_store_next_id 3 ASSERT_EQ

  second_id pebbles_store_fetch
  MATCH
    Ok {
      DUP pebble_status "blocked" ASSERT_EQ
      pebble_notes HEAD "follow up tomorrow" ASSERT_EQ
    }
    Err {
      DROP
      FALSE ASSERT_TRUE
    }
  END
END
